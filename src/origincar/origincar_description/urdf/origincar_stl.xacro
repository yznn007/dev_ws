<?xml version="1.0" encoding="utf-8"?>
<robot name="mycar" xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:property name="FrontWheelX" value="0.06"/>
  <xacro:property name="RearWheelX" value="0.0841"/>
  <xacro:property name="WheelY" value="0.08"/>
  <xacro:property name="WheelZ" value="0.025"/>
  <xacro:property name="base_link_Z" value="0.01"/>


  <xacro:macro name="wheel" params="prefix x y z axis_sign">
    <link name="${prefix}_Link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://origincar_description/meshes/${prefix}_Link.STL"/>
        </geometry>
        <material name="">
          <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_Link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 ${axis_sign} 0"/>
    </joint>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_link_Z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_link_Z}" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://origincar_description/meshes/base_link.STL"/>
      </geometry>
      <material name="rgb(54, 42, 42)">
        <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
      </material>
    </visual>
  </link>

  <link name="gyro_link"/>

  <joint name="gyro_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gyro_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:wheel prefix="down_left"  x="${-RearWheelX}" y="${WheelY}"  z="${WheelZ}" axis_sign="1"/>
  <xacro:wheel prefix="down_right" x="${-RearWheelX}" y="${-WheelY}" z="${WheelZ}" axis_sign="-1"/>
  <xacro:wheel prefix="up_left"    x="${FrontWheelX}" y="${WheelY}"  z="${WheelZ}" axis_sign="1"/>
  <xacro:wheel prefix="up_right"   x="${FrontWheelX}" y="${-WheelY}" z="${WheelZ}" axis_sign="-1"/>

  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.025"/>
      </geometry>
      <material name="dark_brown">
        <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.020"/>
      </geometry>
      <material name="dark_brown">
        <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.025 0 0.135" rpy="0 0 0"/>
  </joint>

</robot>
