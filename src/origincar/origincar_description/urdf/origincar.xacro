<?xml version="1.0" encoding="utf-8"?>
<robot name="mycar" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- 基础参数 -->
  <xacro:property name="PI" value="3.1415926"/>
  <xacro:property name="Track" value="0.1682"/>
  <xacro:property name="WheelBase" value="0.189"/>
  <xacro:property name="WheelRadius" value="0.03"/>
  <xacro:property name="WheelWidth" value="0.025"/>
  <xacro:property name="BaseBoxLength" value="0.276"/>
  <xacro:property name="BaseBoxWidth" value="0.164"/>
  <xacro:property name="BaseBoxHeight" value="0.08"/>
  <xacro:property name="SteerLinkLength" value="0.02"/>

  <!-- 前轮转向宏 -->
  <xacro:macro name="front_wheel" params="prefix side_y">
    <!-- 转向关节连接的link -->
    <link name="${prefix}_steer_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.008" length="${SteerLinkLength}"/>
        </geometry>
        <material name="steer_mat">
          <color rgba="0.5 0.5 0.5 1.0"/>
        </material>
      </visual>
    </link>

    <!-- 转向关节（绕Z轴旋转） -->
    <joint name="${prefix}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_steer_link"/>
      <origin xyz="${WheelBase / 2} ${side_y * Track / 2} ${WheelRadius}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.55" upper="0.55" effort="100" velocity="10"/>
    </joint>

    <!-- 驱动轮link -->
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${side_y * (-PI / 2)} 0 0"/>
        <geometry>
          <cylinder radius="${WheelRadius}" length="${WheelWidth}"/>
        </geometry>
        <material name="wheel_mat">
          <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
        </material>
      </visual>
    </link>

    <!-- 驱动关节（绕Y轴旋转） -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_steer_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 ${side_y} 0"/>
    </joint>
  </xacro:macro>

  <!-- 后轮驱动宏 -->
  <xacro:macro name="rear_wheel" params="prefix side_y">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${side_y * (-PI / 2)} 0 0"/>
        <geometry>
          <cylinder radius="${WheelRadius}" length="${WheelWidth}"/>
        </geometry>
        <material name="wheel_mat">
          <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${-WheelBase / 2} ${side_y * Track / 2} ${WheelRadius}" rpy="0 0 0"/>
      <axis xyz="0 ${side_y} 0"/>
    </joint>
  </xacro:macro>

  <!-- base_footprint -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${WheelRadius}" rpy="0 0 0"/>
  </joint>

  <!-- 车体 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${BaseBoxLength} ${BaseBoxWidth} ${BaseBoxHeight}"/>
      </geometry>
      <origin xyz="0 0 ${BaseBoxHeight / 2 + WheelRadius}" rpy="0 0 0"/>
      <material name="rgb(54, 42, 42)">
        <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
      </material>
    </visual>
  </link>

  <!-- IMU link -->
  <link name="gyro_link"/>

  <joint name="gyro_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gyro_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 电路板 -->
  <link name="board_link">
    <visual>
      <geometry>
        <box size="0.200 ${BaseBoxWidth} 0.07"/>
      </geometry>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <material name="rgba(246,152,152,1)">
        <color rgba="0.9647058823529412 0.596078431372549 0.596078431372549 1"/>
      </material>
    </visual>
  </link>

  <joint name="board_joint" type="fixed">
    <parent link="base_link"/>
    <child link="board_link"/>
    <origin xyz="${-(BaseBoxLength - 0.200) / 2} 0 ${WheelRadius + BaseBoxHeight}" rpy="0 0 0"/>
  </joint>

  <!-- 摄像头 -->
  <link name="camera">
    <visual>
      <geometry>
        <box size="0.015 0.045 0.03"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <material name="rgba(93,78,78,1)">
        <color rgba="0.36470588235294116 0.3058823529411765 0.3058823529411765 1"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera"/>
    <origin xyz="${(BaseBoxLength - 0.015) / 2 - 0.01} 0 ${WheelRadius + BaseBoxHeight}" rpy="0 0 0"/>
  </joint>

  <!-- 前轮（转向+驱动） -->
  <xacro:front_wheel prefix="front_left"  side_y="1"/>
  <xacro:front_wheel prefix="front_right" side_y="-1"/>

  <!-- 后轮（仅驱动） -->
  <xacro:rear_wheel prefix="rear_left"  side_y="1"/>
  <xacro:rear_wheel prefix="rear_right" side_y="-1"/>

  <!-- 激光雷达 -->
  <link name="laser">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.025"/>
      </geometry>
      <material name="dark_brown">
        <color rgba="0.21176470588235294 0.16470588235294117 0.16470588235294117 1.0"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.020"/>
      </geometry>
      <material name="dark_brown"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="board_link"/>
    <child link="laser"/>
    <origin xyz="0.073 0 0.07" rpy="0 0 0"/>
  </joint>

</robot>
